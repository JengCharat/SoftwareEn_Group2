{
  "info": {
    "_postman_id": "c12a0000-0000-0000-0000-sc12push00001",
    "name": "Push Notification API Tests — SC#12",
    "description": "Postman collection สำหรับทดสอบ Push Notification API — Story Card #12\n\"As a passenger, I want to get a notification when the driver is about to pick me up so that I can get myself ready or respond to the driver.\"\n\nครอบคลุม:\n- GET    /api/push/vapid-public-key        ดึง VAPID public key\n- POST   /api/push/subscribe               ลงทะเบียน push subscription\n- POST   /api/push/unsubscribe             ยกเลิก push subscription\n- PATCH  /api/bookings/:id/notify-pickup   Driver แจ้ง Passenger (in-app + Web Push)\n\nหมายเหตุ: Web Push pop-up ทำงานได้เฉพาะ HTTPS/localhost เท่านั้น\nTest suite นี้ครอบคลุมเฉพาะ API layer",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",        "value": "http://localhost:3000", "type": "string" },
    { "key": "bookingId",      "value": "", "type": "string" },
    { "key": "notificationId", "value": "", "type": "string" },
    { "key": "passengerToken", "value": "", "type": "string" },
    { "key": "driverToken",    "value": "", "type": "string" },
    { "key": "mockEndpoint",   "value": "https://fcm.googleapis.com/fcm/send/robot-test-endpoint-12345", "type": "string" },
    { "key": "mockP256dh",     "value": "BNbxHKhKAfaFDREZFuNsPomgekPq5BPh6QoZkGsF4A0Iex1XwH4Xfv_uHJrNJI5vA7lX8Zra5", "type": "string" },
    { "key": "mockAuth",       "value": "robotFrameworkTestAuth123", "type": "string" }
  ],
  "item": [

    {
      "name": "Setup",
      "item": [
        {
          "name": "[TC-01] Login as Passenger",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-01: Status 200', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.test('TC-01: Has token', () => pm.expect(body.data).to.have.property('token'));",
            "pm.collectionVariables.set('passengerToken', body.data.token);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"Billy12\",\n  \"password\": \"billy12345678\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
          }, "response": []
        },
        {
          "name": "[TC-02] Login as Driver",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-02: Status 200', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.test('TC-02: Has token', () => pm.expect(body.data).to.have.property('token'));",
            "pm.collectionVariables.set('driverToken', body.data.token);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"user12\",\n  \"password\": \"12345678\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
          }, "response": []
        },
        {
          "name": "[TC-03] Get Confirmed Booking for Driver",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-03: Status 200', () => pm.response.to.have.status(200));",
            "const bookings = pm.response.json().data?.bookings || [];",
            "const confirmed = bookings.find(b => b.status === 'CONFIRMED');",
            "if (confirmed) {",
            "    pm.collectionVariables.set('bookingId', confirmed.id);",
            "    pm.test('TC-03: CONFIRMED booking found — ID saved', () => pm.expect(confirmed.id).to.be.a('string'));",
            "    console.log('Booking ID:', confirmed.id);",
            "} else {",
            "    console.warn('TC-03: No CONFIRMED booking — notify-pickup tests will fail');",
            "    pm.test('TC-03: WARNING — No CONFIRMED booking found', () => pm.expect(true).to.be.true);",
            "}"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{driverToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/bookings/my", "host": ["{{baseUrl}}"], "path": ["api","bookings","my"] }
          }, "response": []
        }
      ]
    },

    {
      "name": "VAPID Public Key",
      "item": [
        {
          "name": "[TC-04] Get VAPID Public Key — 200 (Public Endpoint)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-04: Status 200', () => pm.response.to.have.status(200));",
            "const data = pm.response.json().data;",
            "pm.test('TC-04: Has vapidPublicKey', () => pm.expect(data).to.have.property('vapidPublicKey'));",
            "pm.test('TC-04: vapidPublicKey is not null', () => pm.expect(data.vapidPublicKey).to.not.be.null);",
            "pm.test('TC-04: vapidPublicKey is not empty', () => pm.expect(data.vapidPublicKey).to.be.a('string').and.not.empty);",
            "pm.collectionVariables.set('vapidPublicKey', data.vapidPublicKey);",
            "console.log('VAPID Public Key:', data.vapidPublicKey);"
          ]}}],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/push/vapid-public-key", "host": ["{{baseUrl}}"], "path": ["api","push","vapid-public-key"] }
          }, "response": []
        },
        {
          "name": "[TC-05] VAPID Response Has No Private Key",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-05: Status 200', () => pm.response.to.have.status(200));",
            "const data = pm.response.json().data;",
            "pm.test('TC-05: No vapidPrivateKey in response', () => pm.expect(data).to.not.have.property('vapidPrivateKey'));",
            "pm.test('TC-05: No privateKey in response', () => pm.expect(data).to.not.have.property('privateKey'));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/push/vapid-public-key", "host": ["{{baseUrl}}"], "path": ["api","push","vapid-public-key"] }
          }, "response": []
        },
        {
          "name": "[TC-06] VAPID Key is Valid Base64url Format (length >= 80)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-06: Status 200', () => pm.response.to.have.status(200));",
            "const key = pm.response.json().data.vapidPublicKey;",
            "pm.test('TC-06: Key length >= 80 chars', () => pm.expect(key.length).to.be.at.least(80));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/push/vapid-public-key", "host": ["{{baseUrl}}"], "path": ["api","push","vapid-public-key"] }
          }, "response": []
        }
      ]
    },

    {
      "name": "Push Subscribe",
      "item": [
        {
          "name": "[TC-07] Passenger Subscribes to Push — 201",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-07: Status 201', () => pm.response.to.have.status(201));",
            "pm.test('TC-07: success = true', () => pm.expect(pm.response.json().success).to.be.true);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{passengerToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"endpoint\": \"{{mockEndpoint}}\",\n  \"keys\": {\n    \"p256dh\": \"{{mockP256dh}}\",\n    \"auth\": \"{{mockAuth}}\"\n  }\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/push/subscribe", "host": ["{{baseUrl}}"], "path": ["api","push","subscribe"] }
          }, "response": []
        },
        {
          "name": "[TC-08] Subscribe Same Endpoint Again — Idempotent (Not 500)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-08: Not 500 (idempotent)', () => pm.expect(pm.response.code).to.be.below(500));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{passengerToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"endpoint\": \"{{mockEndpoint}}\",\n  \"keys\": {\n    \"p256dh\": \"{{mockP256dh}}\",\n    \"auth\": \"{{mockAuth}}\"\n  }\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/push/subscribe", "host": ["{{baseUrl}}"], "path": ["api","push","subscribe"] }
          }, "response": []
        },
        {
          "name": "[TC-09] Subscribe Without Token — 401",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-09: Status 401', () => pm.response.to.have.status(401));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"endpoint\": \"{{mockEndpoint}}\",\n  \"keys\": {\n    \"p256dh\": \"{{mockP256dh}}\",\n    \"auth\": \"{{mockAuth}}\"\n  }\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/push/subscribe", "host": ["{{baseUrl}}"], "path": ["api","push","subscribe"] }
          }, "response": []
        },
        {
          "name": "[TC-10] Subscribe with Invalid Endpoint (not URL) — 400",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-10: Status 400', () => pm.response.to.have.status(400));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{passengerToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"endpoint\": \"not-a-valid-url\",\n  \"keys\": {\n    \"p256dh\": \"{{mockP256dh}}\",\n    \"auth\": \"{{mockAuth}}\"\n  }\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/push/subscribe", "host": ["{{baseUrl}}"], "path": ["api","push","subscribe"] }
          }, "response": []
        },
        {
          "name": "[TC-11] Subscribe with Missing Keys — 400",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-11: Status 400', () => pm.response.to.have.status(400));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{passengerToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"endpoint\": \"{{mockEndpoint}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/push/subscribe", "host": ["{{baseUrl}}"], "path": ["api","push","subscribe"] }
          }, "response": []
        }
      ]
    },

    {
      "name": "Push Unsubscribe",
      "item": [
        {
          "name": "[TC-12] Passenger Unsubscribes from Push — 200",
          "event": [
            { "listen": "pre-request", "script": { "type": "text/javascript", "exec": [
              "// Re-subscribe first to ensure the endpoint exists",
              "const req = {",
              "    url: pm.collectionVariables.get('baseUrl') + '/api/push/subscribe',",
              "    method: 'POST',",
              "    header: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + pm.collectionVariables.get('passengerToken') },",
              "    body: { mode: 'raw', raw: JSON.stringify({ endpoint: pm.collectionVariables.get('mockEndpoint'), keys: { p256dh: pm.collectionVariables.get('mockP256dh'), auth: pm.collectionVariables.get('mockAuth') } }) }",
              "};",
              "pm.sendRequest(req, () => {});"
            ]}},
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('TC-12: Status 200', () => pm.response.to.have.status(200));",
              "pm.test('TC-12: success = true', () => pm.expect(pm.response.json().success).to.be.true);"
            ]}}
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{passengerToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"endpoint\": \"{{mockEndpoint}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/push/unsubscribe", "host": ["{{baseUrl}}"], "path": ["api","push","unsubscribe"] }
          }, "response": []
        },
        {
          "name": "[TC-13] Unsubscribe Non-existent Endpoint — Idempotent (Not 500)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-13: Not 500 (idempotent)', () => pm.expect(pm.response.code).to.be.below(500));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{passengerToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"endpoint\": \"https://fcm.googleapis.com/fcm/send/non-existent-9999\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/push/unsubscribe", "host": ["{{baseUrl}}"], "path": ["api","push","unsubscribe"] }
          }, "response": []
        },
        {
          "name": "[TC-14] Unsubscribe Without Token — 401",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-14: Status 401', () => pm.response.to.have.status(401));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"endpoint\": \"{{mockEndpoint}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/push/unsubscribe", "host": ["{{baseUrl}}"], "path": ["api","push","unsubscribe"] }
          }, "response": []
        }
      ]
    },

    {
      "name": "Notify Pickup",
      "item": [
        {
          "name": "[TC-15] Driver Notifies Passenger — Creates In-App Notification",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-15: Status 200', () => pm.response.to.have.status(200));",
            "const data = pm.response.json().data;",
            "pm.test('TC-15: Has notification id', () => pm.expect(data).to.have.property('id'));",
            "pm.collectionVariables.set('notificationId', data.id);",
            "pm.test('TC-15: type = BOOKING', () => pm.expect(data.type).to.eql('BOOKING'));",
            "pm.test('TC-15: metadata.kind = DRIVER_ON_THE_WAY', () => pm.expect(data.metadata.kind).to.eql('DRIVER_ON_THE_WAY'));",
            "pm.test('TC-15: metadata.bookingId matches', () => pm.expect(data.metadata.bookingId).to.eql(pm.collectionVariables.get('bookingId')));",
            "console.log('Notification ID:', data.id);"
          ]}}],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{driverToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/notify-pickup", "host": ["{{baseUrl}}"], "path": ["api","bookings","{{bookingId}}","notify-pickup"] }
          }, "response": []
        },
        {
          "name": "[TC-16] Passenger Can See Notification in Inbox",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-16: Status 200', () => pm.response.to.have.status(200));",
            "const notifications = pm.response.json().data?.notifications || [];",
            "const notifId = pm.collectionVariables.get('notificationId');",
            "const found = notifications.find(n => n.id === notifId);",
            "pm.test('TC-16: Notification found in inbox', () => pm.expect(found).to.not.be.undefined);",
            "pm.test('TC-16: Title contains คนขับกำลังมารับคุณแล้ว', () => pm.expect(found.title).to.include('คนขับกำลังมารับคุณแล้ว'));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{passengerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/notifications", "host": ["{{baseUrl}}"], "path": ["api","notifications"] }
          }, "response": []
        },
        {
          "name": "[TC-17] Second Notify Within 3 Minutes — 429 Cooldown",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-17: Status 429 (cooldown)', () => pm.response.to.have.status(429));"
          ]}}],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{driverToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/notify-pickup", "host": ["{{baseUrl}}"], "path": ["api","bookings","{{bookingId}}","notify-pickup"] }
          }, "response": []
        },
        {
          "name": "[TC-18] Passenger Cannot Call Notify-Pickup — 403",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-18: Status 403', () => pm.response.to.have.status(403));"
          ]}}],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{passengerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/notify-pickup", "host": ["{{baseUrl}}"], "path": ["api","bookings","{{bookingId}}","notify-pickup"] }
          }, "response": []
        },
        {
          "name": "[TC-19] Unauthenticated Cannot Call Notify-Pickup — 401",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-19: Status 401', () => pm.response.to.have.status(401));"
          ]}}],
          "request": {
            "method": "PATCH",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/notify-pickup", "host": ["{{baseUrl}}"], "path": ["api","bookings","{{bookingId}}","notify-pickup"] }
          }, "response": []
        },
        {
          "name": "[TC-20] Notify Non-existent Booking — 404",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-20: Status 404 or 400', () => {",
            "    pm.expect([400, 404]).to.include(pm.response.code);",
            "});"
          ]}}],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{driverToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/bookings/clzzzzzzzzzzzzzzzzzzzzzzzz/notify-pickup", "host": ["{{baseUrl}}"], "path": ["api","bookings","clzzzzzzzzzzzzzzzzzzzzzzzz","notify-pickup"] }
          }, "response": []
        },
        {
          "name": "[TC-21] Notification Has Correct Metadata",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-21: Status 200', () => pm.response.to.have.status(200));",
            "const notifications = pm.response.json().data?.notifications || [];",
            "const notifId = pm.collectionVariables.get('notificationId');",
            "const found = notifications.find(n => n.id === notifId);",
            "pm.test('TC-21: Notification found', () => pm.expect(found).to.not.be.undefined);",
            "pm.test('TC-21: metadata.kind = DRIVER_ON_THE_WAY', () => pm.expect(found.metadata.kind).to.eql('DRIVER_ON_THE_WAY'));",
            "pm.test('TC-21: metadata.bookingId correct', () => pm.expect(found.metadata.bookingId).to.eql(pm.collectionVariables.get('bookingId')));",
            "pm.test('TC-21: metadata.driverId not empty', () => pm.expect(found.metadata.driverId).to.be.a('string').and.not.empty);"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{passengerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/notifications", "host": ["{{baseUrl}}"], "path": ["api","notifications"] }
          }, "response": []
        }
      ]
    }

  ]
