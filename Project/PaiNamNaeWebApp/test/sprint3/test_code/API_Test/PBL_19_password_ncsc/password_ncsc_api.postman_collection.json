{
  "info": {
    "_postman_id": "c19a0000-0000-0000-0000-sc19ncsc0001",
    "name": "Password NCSC UK API Tests — SC#19",
    "description": "Postman collection สำหรับทดสอบ Password NCSC UK Guidelines — Story Card #19\n\"As a user, I want to keep my password matched to the NCSC UK's guidelines, so that my account is safe.\"\n\nครอบคลุม:\n- POST /api/auth/register — ตรวจรหัสผ่าน word list + min 10 chars ตอนสมัคร\n- PATCH /api/auth/change-password — ตรวจรหัสผ่าน word list + permutation ตอนเปลี่ยน\n\nACCEPTANCE CRITERIA:\n- AC-1: min 10 chars\n- AC-2: exact match word list (case-insensitive)\n- AC-3: substring match (word >= 5 chars) ยกเว้น passphrase\n- AC-5: Backend validation ผ่าน Zod .refine()\n- AC-6: Change password enforce NCSC check\n- AC-7: Anagram/permutation check",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",          "value": "http://10.198.200.88:3002", "type": "string" },
    { "key": "passengerToken",   "value": "", "type": "string" },
    { "key": "testUserId",       "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Setup",
      "item": [
        {
          "name": "[TC-01] Login as Existing Passenger",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-01: Status 200', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.test('TC-01: Has token', () => pm.expect(body.data).to.have.property('token'));",
            "pm.collectionVariables.set('passengerToken', body.data.token);",
            "pm.collectionVariables.set('testUserId', body.data.user.id);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"Billy12\",\n  \"password\": \"billy12345678\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
          }
        }
      ]
    },
    {
      "name": "Register — Password Length (AC-1)",
      "item": [
        {
          "name": "[TC-02] Register with password < 10 chars → 400",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-02: Status 400', () => pm.response.to.have.status(400));",
            "const body = pm.response.json();",
            "pm.test('TC-02: Error mentions min length', () => {",
            "    const msg = JSON.stringify(body).toLowerCase();",
            "    pm.expect(msg).to.include('10');",
            "});"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"ncsc_test_short@test.com\",\n  \"username\": \"ncsctest01\",\n  \"password\": \"short9chr\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"Short\",\n  \"phoneNumber\": \"0812345678\",\n  \"gender\": \"MALE\",\n  \"nationalIdNumber\": \"1234567890123\",\n  \"nationalIdExpiryDate\": \"2030-01-01T00:00:00.000Z\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] }
          }
        },
        {
          "name": "[TC-03] Register with password exactly 10 chars (valid) — should pass length check",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "// This test checks length only — may still fail on word list",
            "// If 200/201 → length check passed. If 400 with 'word list' → length OK but word list caught it",
            "const status = pm.response.code;",
            "const body = pm.response.json();",
            "const msg = JSON.stringify(body).toLowerCase();",
            "if (status === 400) {",
            "    pm.test('TC-03: If 400, error is NOT about length', () => {",
            "        pm.expect(msg).to.not.include('at least 10');",
            "    });",
            "} else {",
            "    pm.test('TC-03: Status 201 — registration accepted', () => pm.response.to.have.status(201));",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"ncsc_test_10@test.com\",\n  \"username\": \"ncsctest02\",\n  \"password\": \"xY3kq8m2Lp\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"TenChar\",\n  \"phoneNumber\": \"0812345679\",\n  \"gender\": \"MALE\",\n  \"nationalIdNumber\": \"1234567890124\",\n  \"nationalIdExpiryDate\": \"2030-01-01T00:00:00.000Z\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] }
          }
        }
      ]
    },
    {
      "name": "Register — Word List Exact Match (AC-2, AC-5)",
      "item": [
        {
          "name": "[TC-04] Register with common password 'password123' → 400 word list",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-04: Status 400', () => pm.response.to.have.status(400));",
            "const body = pm.response.json();",
            "const msg = JSON.stringify(body).toLowerCase();",
            "pm.test('TC-04: Error mentions word list / common', () => {",
            "    pm.expect(msg).to.satisfy(m => m.includes('word list') || m.includes('common'));",
            "});"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"ncsc_common1@test.com\",\n  \"username\": \"ncsccommon1\",\n  \"password\": \"password123\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"Common\",\n  \"phoneNumber\": \"0812345680\",\n  \"gender\": \"MALE\",\n  \"nationalIdNumber\": \"1234567890125\",\n  \"nationalIdExpiryDate\": \"2030-01-01T00:00:00.000Z\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] }
          }
        },
        {
          "name": "[TC-05] Register with common password 'qwerty12345' → 400 word list",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-05: Status 400', () => pm.response.to.have.status(400));",
            "const msg = JSON.stringify(pm.response.json()).toLowerCase();",
            "pm.test('TC-05: Error mentions word list / common', () => {",
            "    pm.expect(msg).to.satisfy(m => m.includes('word list') || m.includes('common'));",
            "});"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"ncsc_common2@test.com\",\n  \"username\": \"ncsccommon2\",\n  \"password\": \"qwerty12345\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"Common2\",\n  \"phoneNumber\": \"0812345681\",\n  \"gender\": \"MALE\",\n  \"nationalIdNumber\": \"1234567890126\",\n  \"nationalIdExpiryDate\": \"2030-01-01T00:00:00.000Z\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] }
          }
        },
        {
          "name": "[TC-06] Register with case-insensitive common 'PASSWORD123' → 400",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-06: Status 400', () => pm.response.to.have.status(400));",
            "pm.test('TC-06: Blocked by word list', () => {",
            "    const msg = JSON.stringify(pm.response.json()).toLowerCase();",
            "    pm.expect(msg).to.satisfy(m => m.includes('word list') || m.includes('common'));",
            "});"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"ncsc_common3@test.com\",\n  \"username\": \"ncsccommon3\",\n  \"password\": \"PASSWORD123\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"CaseTest\",\n  \"phoneNumber\": \"0812345682\",\n  \"gender\": \"MALE\",\n  \"nationalIdNumber\": \"1234567890127\",\n  \"nationalIdExpiryDate\": \"2030-01-01T00:00:00.000Z\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] }
          }
        }
      ]
    },
    {
      "name": "Register — Substring Match (AC-3)",
      "item": [
        {
          "name": "[TC-07] Register with 'password' embedded 'mypassword99' → 400",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-07: Status 400 — substring detected', () => pm.response.to.have.status(400));",
            "pm.test('TC-07: Word list error', () => {",
            "    const msg = JSON.stringify(pm.response.json()).toLowerCase();",
            "    pm.expect(msg).to.satisfy(m => m.includes('word list') || m.includes('common'));",
            "});"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"ncsc_sub1@test.com\",\n  \"username\": \"ncscsub001\",\n  \"password\": \"mypassword99\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"Substr\",\n  \"phoneNumber\": \"0812345683\",\n  \"gender\": \"MALE\",\n  \"nationalIdNumber\": \"1234567890128\",\n  \"nationalIdExpiryDate\": \"2030-01-01T00:00:00.000Z\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] }
          }
        },
        {
          "name": "[TC-08] Passphrase 'summer-coffee-pizza' → ALLOWED (AC-3 exception)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "// Passphrase with '-' separator should NOT be blocked by substring check",
            "const status = pm.response.code;",
            "const msg = JSON.stringify(pm.response.json()).toLowerCase();",
            "pm.test('TC-08: Not blocked by word list', () => {",
            "    pm.expect(msg).to.not.include('word list');",
            "    pm.expect(msg).to.not.include('common');",
            "});"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"ncsc_passphrase@test.com\",\n  \"username\": \"ncscphrase1\",\n  \"password\": \"summer-coffee-pizza\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"Passphrase\",\n  \"phoneNumber\": \"0812345684\",\n  \"gender\": \"MALE\",\n  \"nationalIdNumber\": \"1234567890129\",\n  \"nationalIdExpiryDate\": \"2030-01-01T00:00:00.000Z\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] }
          }
        }
      ]
    },
    {
      "name": "Change Password — NCSC Check (AC-6)",
      "item": [
        {
          "name": "[TC-09] Change password with common word → 400",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-09: Status 400', () => pm.response.to.have.status(400));",
            "const msg = JSON.stringify(pm.response.json()).toLowerCase();",
            "pm.test('TC-09: Blocked by word list or min length', () => {",
            "    pm.expect(msg).to.satisfy(m => m.includes('word list') || m.includes('common') || m.includes('10'));",
            "});"
          ]}}],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{passengerToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"billy12345678\",\n  \"newPassword\": \"password123\",\n  \"confirmNewPassword\": \"password123\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/change-password", "host": ["{{baseUrl}}"], "path": ["api","auth","change-password"] }
          }
        },
        {
          "name": "[TC-10] Change password with < 10 chars → 400",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-10: Status 400', () => pm.response.to.have.status(400));",
            "pm.test('TC-10: Error about length', () => {",
            "    const msg = JSON.stringify(pm.response.json()).toLowerCase();",
            "    pm.expect(msg).to.include('10');",
            "});"
          ]}}],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{passengerToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"billy12345678\",\n  \"newPassword\": \"short123\",\n  \"confirmNewPassword\": \"short123\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/change-password", "host": ["{{baseUrl}}"], "path": ["api","auth","change-password"] }
          }
        },
        {
          "name": "[TC-11] Change password — mismatch confirm → 400",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-11: Status 400', () => pm.response.to.have.status(400));",
            "pm.test('TC-11: Error about mismatch', () => {",
            "    const msg = JSON.stringify(pm.response.json()).toLowerCase();",
            "    pm.expect(msg).to.satisfy(m => m.includes('match') || m.includes('confirm'));",
            "});"
          ]}}],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{passengerToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"billy12345678\",\n  \"newPassword\": \"mynewsafepassword99\",\n  \"confirmNewPassword\": \"differentpassword99\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/change-password", "host": ["{{baseUrl}}"], "path": ["api","auth","change-password"] }
          }
        },
        {
          "name": "[TC-12] Change password — no auth → 401",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-12: Status 401', () => pm.response.to.have.status(401));"
          ]}}],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"billy12345678\",\n  \"newPassword\": \"safenewpassword99\",\n  \"confirmNewPassword\": \"safenewpassword99\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/change-password", "host": ["{{baseUrl}}"], "path": ["api","auth","change-password"] }
          }
        }
      ]
    },
    {
      "name": "Change Password — Permutation Check (AC-7)",
      "item": [
        {
          "name": "[TC-13] Change password to anagram of current → 400 permutation",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-13: Status 400', () => pm.response.to.have.status(400));",
            "pm.test('TC-13: Error about permutation', () => {",
            "    const msg = JSON.stringify(pm.response.json()).toLowerCase();",
            "    pm.expect(msg).to.satisfy(m => m.includes('permutation') || m.includes('anagram') || m.includes('rearrange') || m.includes('สลับ'));",
            "});"
          ]}}],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{passengerToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"billy12345678\",\n  \"newPassword\": \"8billy1234567\",\n  \"confirmNewPassword\": \"8billy1234567\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/change-password", "host": ["{{baseUrl}}"], "path": ["api","auth","change-password"] }
          }
        }
      ]
    }
  ]
}
