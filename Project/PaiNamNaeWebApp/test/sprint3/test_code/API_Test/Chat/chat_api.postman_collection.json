{
  "info": {
    "_postman_id": "c10a0000-0000-0000-0000-sc10chat00001",
    "name": "Chat API Tests — SC#10",
    "description": "Postman collection สำหรับทดสอบ Chat/Message API — Story Card #10\n\"As a driver, I want to send a message to a passenger without revealing too much personal information so that I can communicate with them in a safer manner.\"\n\nครอบคลุม:\n- GET    /api/bookings/:bookingId/chat              ดึงข้อมูลห้องแชท\n- GET    /api/bookings/:bookingId/messages          ดึงรายการข้อความ\n- POST   /api/bookings/:bookingId/messages          ส่งข้อความ + PII detection\n- GET    /api/bookings/:bookingId/messages/unread-count\n- PATCH  /api/bookings/:bookingId/messages/read-all\n- PATCH  /api/bookings/:bookingId/messages/:messageId/read",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",    "value": "http://localhost:3000", "type": "string" },
    { "key": "bookingId",  "value": "", "type": "string" },
    { "key": "messageId",  "value": "", "type": "string" },
    { "key": "passengerToken", "value": "", "type": "string" },
    { "key": "driverToken",    "value": "", "type": "string" },
    { "key": "adminToken",     "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "Setup",
      "item": [
        {
          "name": "[TC-01] Login as Passenger",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-01: Status 200', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.test('TC-01: Has token', () => pm.expect(body.data).to.have.property('token'));",
            "pm.collectionVariables.set('passengerToken', body.data.token);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"Billy12\",\n  \"password\": \"billy12345678\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
          }, "response": []
        },
        {
          "name": "[TC-02] Login as Driver",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-02: Status 200', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.test('TC-02: Has token', () => pm.expect(body.data).to.have.property('token'));",
            "pm.collectionVariables.set('driverToken', body.data.token);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"user12\",\n  \"password\": \"12345678\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
          }, "response": []
        },
        {
          "name": "[TC-03] Get Confirmed Booking ID",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-03: Status 200', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "const bookings = body.data?.bookings || [];",
            "const confirmed = bookings.find(b => b.status === 'CONFIRMED' || b.status === 'PENDING');",
            "if (confirmed) {",
            "    pm.collectionVariables.set('bookingId', confirmed.id);",
            "    pm.test('TC-03: Found usable booking — ID saved', () => pm.expect(confirmed.id).to.be.a('string'));",
            "    console.log('Booking ID:', confirmed.id);",
            "} else {",
            "    console.warn('TC-03: No CONFIRMED booking found — subsequent tests may be skipped');",
            "    pm.test('TC-03: WARNING — No confirmed booking found', () => pm.expect(true).to.be.true);",
            "}"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{passengerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/bookings/my", "host": ["{{baseUrl}}"], "path": ["api","bookings","my"] }
          }, "response": []
        }
      ]
    },

    {
      "name": "Chat Room",
      "item": [
