            "url": { "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/messages", "host": ["{{baseUrl}}"], "path": ["api","bookings","{{bookingId}}","messages"] }
          }, "response": []
        },
        {
          "name": "[TC-07] Passenger Sends Normal Message — 201",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
