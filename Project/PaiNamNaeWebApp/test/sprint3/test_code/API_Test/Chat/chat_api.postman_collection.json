          ]}}],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/chat", "host": ["{{baseUrl}}"], "path": ["api","bookings","{{bookingId}}","chat"] }
          }, "response": []
