            "const data = pm.response.json().data;",
            "pm.test('TC-06: Has message id', () => pm.expect(data).to.have.property('id'));",
            "pm.collectionVariables.set('messageId', data.id);",
            "const warn = data.personalInfoWarning;",
            "pm.test('TC-06: No PII warning (normal message)', () => {",
            "    if (warn) { pm.expect(warn.detected).to.be.false; }",
            "    else { pm.expect(true).to.be.true; }",
            "});"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{driverToken}}" }, { "key": "Content-Type", "value": "application/json" }],
