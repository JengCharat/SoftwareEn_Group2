            "const data = pm.response.json().data;",
            "pm.test('TC-07: senderRole = PASSENGER', () => pm.expect(data.senderRole).to.eql('PASSENGER'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{passengerToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"content\": \"โอเคครับ ผมรอที่จุดนัดพบอยู่นะครับ\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/messages", "host": ["{{baseUrl}}"], "path": ["api","bookings","{{bookingId}}","messages"] }
          }, "response": []
