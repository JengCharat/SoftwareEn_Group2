        {
          "name": "[TC-08] Create Review — Success with Comment (201)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-08: Status 201 Created', () => pm.response.to.have.status(201));",
            "const body = pm.response.json();",
            "pm.test('TC-08: success = true', () => pm.expect(body.success).to.be.true);",
            "const review = body.data;",
            "pm.test('TC-08: Has review id', () => pm.expect(review).to.have.property('id'));",
            "pm.test('TC-08: rating = 4', () => pm.expect(review.rating).to.equal(4));",
            "pm.test('TC-08: Has comment', () => pm.expect(review.comment).to.equal('บริการดีมาก คนขับสุภาพ'));",
            "pm.test('TC-08: Has driverId', () => pm.expect(review).to.have.property('driverId'));",
            "pm.test('TC-08: Has passengerId', () => pm.expect(review).to.have.property('passengerId'));",
            "pm.collectionVariables.set('reviewId', review.id);",
            "console.log('Review ID saved:', review.id);"
          ]}}],
          "request": {
