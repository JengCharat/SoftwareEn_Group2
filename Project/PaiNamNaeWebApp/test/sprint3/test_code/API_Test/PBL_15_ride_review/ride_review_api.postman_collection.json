{
  "info": {
    "_postman_id": "c15a0000-0000-0000-0000-sc15review0001",
    "name": "Ride Review API Tests — SC#15",
    "description": "Postman collection สำหรับทดสอบ Ride Review API — Story Card #15\n\"As a passenger, I want to give a review for each ride that I took to support the community.\"\n\nครอบคลุม:\n- POST   /api/reviews                      สร้างรีวิว\n- GET    /api/reviews/my                   ดูรีวิวของตัวเอง\n- GET    /api/reviews/driver/:driverId     ดูรีวิวของคนขับ + คะแนนเฉลี่ย\n- PATCH  /api/reviews/:reviewId            แก้ไขรีวิว\n- DELETE /api/reviews/:reviewId            ลบรีวิว\n\nTest Accounts:\n- Passenger: Billy12 / billy12345678\n- Driver:    user12  / 12345678\n\nหมายเหตุ: ต้องมีการจองที่สถานะ COMPLETED เท่านั้นถึงจะรีวิวได้ (คนขับต้องกด PATCH /bookings/:id/complete ก่อน)\nก่อนรัน TC-05 ให้เซ็ต bookingId ที่เหมาะสมใน Collection Variables",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",        "value": "http://10.198.200.88:3002", "type": "string" },
    { "key": "passengerToken", "value": "", "type": "string" },
    { "key": "driverToken",    "value": "", "type": "string" },
    { "key": "driverId",       "value": "", "type": "string" },
    { "key": "bookingId",      "value": "", "type": "string" },
    { "key": "reviewId",       "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "Setup",
      "item": [
        {
          "name": "[TC-01] Login as Passenger",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-01: Status 200', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.test('TC-01: Has token', () => pm.expect(body.data).to.have.property('token'));",
            "pm.collectionVariables.set('passengerToken', body.data.token);",
            "console.log('Passenger token saved');"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"Billy12\",\n  \"password\": \"billy12345678\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
          }, "response": []
        },
        {
          "name": "[TC-02] Login as Driver",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-02: Status 200', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.test('TC-02: Has token', () => pm.expect(body.data).to.have.property('token'));",
            "pm.collectionVariables.set('driverToken', body.data.token);",
            "const user = body.data.user;",
            "if (user && user.id) pm.collectionVariables.set('driverId', user.id);",
            "console.log('Driver ID:', user ? user.id : 'N/A');"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"user12\",\n  \"password\": \"12345678\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
          }, "response": []
        },
        {
          "name": "[TC-03] Get Passenger Bookings — Save Eligible bookingId",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('TC-03: Status 200', () => pm.response.to.have.status(200));",
            "const bookings = pm.response.json().data || [];",
            "pm.test('TC-03: Response data is array', () => pm.expect(bookings).to.be.an('array'));",
            "",
            "// หา COMPLETED booking (ไม่มี review ก่อน, ถ้าไม่เจอก็เอาที่มี review แล้วลบทีหลัง)",
            "const noReview = bookings.find(b => b.status === 'COMPLETED' && !b.review);",
            "const withReview = bookings.find(b => b.status === 'COMPLETED' && b.review);",
            "const eligible = noReview || withReview;",
            "",
            "if (eligible) {",
            "  pm.collectionVariables.set('bookingId', eligible.id);",
            "  if (eligible.route && eligible.route.driverId) pm.collectionVariables.set('driverId', eligible.route.driverId);",
            "  console.log('Eligible booking found:', eligible.id, '| hasReview:', !!eligible.review);",
            "",
            "  // ถ้ามี review อยู่แล้ว → ลบก่อนเพื่อให้ TC-08 สร้างใหม่ได้",
            "  if (eligible.review) {",
            "    const delUrl = pm.collectionVariables.get('baseUrl') + '/api/reviews/' + eligible.review.id;",
            "    pm.sendRequest({ url: delUrl, method: 'DELETE', header: { 'Authorization': 'Bearer ' + pm.collectionVariables.get('passengerToken') } },",
            "      (err, res) => { console.log('Cleanup old review:', eligible.review.id, '→', res ? res.code : err); });",
            "  }",
            "  pm.test('TC-03: Found eligible booking', () => pm.expect(eligible.id).to.be.a('string'));",
            "} else {",
            "  console.warn('No COMPLETED booking found — set bookingId manually');",
            "  pm.test('TC-03: Eligible booking check (may be skipped)', () => true);",
            "}"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{passengerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/bookings/me", "host": ["{{baseUrl}}"], "path": ["api","bookings","me"] }
          }, "response": []
        }
      ]
    },

