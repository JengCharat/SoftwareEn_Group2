    {
      "name": "Create Report",
      "item": [
        {
          "name": "[POST /reports] Happy path - สร้างรายงานสำเร็จ",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 - Report created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "let body = pm.response.json();",
                  "pm.test('success = true', function () {",
                  "    pm.expect(body.success).to.be.true;",
                  "});",
                  "",
                  "pm.test('data has required fields', function () {",
                  "    pm.expect(body.data).to.have.property('id');",
                  "    pm.expect(body.data).to.have.property('reporterId');",
                  "    pm.expect(body.data).to.have.property('reportedDriverId');",
                  "    pm.expect(body.data).to.have.property('reason');",
                  "    pm.expect(body.data).to.have.property('description');",
                  "    pm.expect(body.data).to.have.property('status');",
                  "});",
                  "",
                  "pm.test('status is PENDING', function () {",
                  "    pm.expect(body.data.status).to.equal('PENDING');",
                  "});",
                  "",
                  "pm.test('reason matches input', function () {",
                  "    pm.expect(body.data.reason).to.equal('RECKLESS_DRIVING');",
                  "});",
                  "",
                  "pm.collectionVariables.set('reportId', body.data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{passengerToken}}", "type": "text" }
            ],
            "body": {
              "mode": "formdata",
