                  "});",
                  "",
                  "pm.test('data has message fields', function () {",
                  "    pm.expect(body.data).to.have.property('id');",
                  "    pm.expect(body.data).to.have.property('bookingId');",
                  "    pm.expect(body.data).to.have.property('senderRole');",
