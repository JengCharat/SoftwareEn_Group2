          "name": "[GET /messages] sortOrder=desc (เรียงจากใหม่ไปเก่า)",
          "id": "33333333-0001-0001-0001-000000000003",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "let body = pm.response.json();",
                  "pm.test('Messages sorted desc (newest first)', function () {",
                  "    let msgs = body.data;",
                  "    for (let i = 0; i < msgs.length - 1; i++) {",
                  "        let curr = new Date(msgs[i].createdAt).getTime();",
                  "        let next = new Date(msgs[i+1].createdAt).getTime();",
                  "        pm.expect(curr).to.be.at.least(next);",
                  "    }",
