    {
      "name": "Chat Room",
      "item": [
        {
          "name": "[GET /chat] Happy path - ดึงข้อมูลห้องแชท",
          "id": "22222222-0001-0001-0001-000000000001",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "let body = pm.response.json();",
                  "pm.test('success = true', function () {",
                  "    pm.expect(body.success).to.be.true;",
                  "});",
                  "",
                  "pm.test('data has required fields', function () {",
                  "    pm.expect(body.data).to.have.property('bookingId');",
                  "    pm.expect(body.data).to.have.property('status');",
                  "    pm.expect(body.data).to.have.property('myRole');",
                  "    pm.expect(body.data).to.have.property('chatPartner');",
                  "    pm.expect(body.data).to.have.property('route');",
                  "    pm.expect(body.data).to.have.property('vehicle');",
                  "    pm.expect(body.data).to.have.property('unreadCount');",
                  "});",
                  "",
                  "pm.test('myRole is DRIVER or PASSENGER', function () {",
                  "    pm.expect(['DRIVER', 'PASSENGER']).to.include(body.data.myRole);",
                  "});",
                  "",
                  "pm.test('chatPartner does NOT expose sensitive user data', function () {",
                  "    pm.expect(body.data.chatPartner).to.not.have.property('email');",
                  "    pm.expect(body.data.chatPartner).to.not.have.property('phone');",
                  "    pm.expect(body.data.chatPartner).to.not.have.property('nationalId');",
                  "});",
                  "",
                  "pm.test('status is valid enum', function () {",
                  "    pm.expect(['PENDING','CONFIRMED','REJECTED','CANCELLED']).to.include(body.data.status);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
