                  "});",
                  "",
                  "pm.test('senderId is NOT exposed', function () {",
                  "    pm.expect(body.data).to.not.have.property('senderId');",
                  "});",
                  "",
                  "pm.test('readAt is null initially', function () {",
                  "    pm.expect(body.data.readAt).to.be.null;",
                  "});",
                  "",
                  "// Save messageId for mark-read tests",
