                  "pm.test('success = true', function () {",
                  "    pm.expect(body.success).to.be.true;",
                  "});",
                  "",
                  "pm.test('data is array', function () {",
                  "    pm.expect(body.data).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('pagination object present', function () {",
                  "    pm.expect(body.pagination).to.have.property('page');",
                  "    pm.expect(body.pagination).to.have.property('limit');",
                  "    pm.expect(body.pagination).to.have.property('total');",
                  "    pm.expect(body.pagination).to.have.property('totalPages');",
                  "});",
                  "",
                  "pm.test('messages do NOT expose senderId', function () {",
                  "    body.data.forEach(function (msg) {",
                  "        pm.expect(msg).to.not.have.property('senderId');",
                  "        pm.expect(msg).to.have.property('senderRole');",
                  "        pm.expect(['DRIVER','PASSENGER']).to.include(msg.senderRole);",
                  "    });",
                  "});",
                  "",
                  "// Save first messageId for later tests",
                  "if (body.data.length > 0) {",
                  "    pm.environment.set('messageId', body.data[0].id);",
                  "    console.log('messageId saved:', body.data[0].id);",
                  "}"
